<?xml version="1.0" encoding="UTF-8"?>
<!--
    web.xml - Web Application Deployment Descriptor
    
    This is the configuration file for the Java web application.
    It tells the server (Tomcat) how to handle incoming requests.
    
    What web.xml configures:
    1. Servlet definitions (which class handles requests)
    2. Servlet mappings (which URL patterns map to which servlet)
    3. Welcome files (default page when no file is specified)
    
    Location: WEB-INF/web.xml
    WEB-INF directory is special - its contents are not accessible via URL
    This prevents users from accessing configuration files directly.
-->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
    
    <!-- 
        ==========================================
        SERVLET DEFINITION
        ==========================================
        
        <servlet> defines a servlet by:
        - servlet-name: Logical name used within this file
        - servlet-class: Fully qualified Java class name
        
        When Tomcat starts, it loads this class and creates one instance.
    -->
    <servlet>
        <servlet-name>CheckURLServlet</servlet-name>
        <!-- Fully qualified class name (package.ClassName) -->
        <servlet-class>com.fakeurldetector.servlet.CheckURLServlet</servlet-class>
    </servlet>
    
    <!-- HistoryServlet - handles view history requests -->
    <servlet>
        <servlet-name>HistoryServlet</servlet-name>
        <servlet-class>com.fakeurldetector.servlet.HistoryServlet</servlet-class>
    </servlet>
    
    <!-- IndexServlet - handles navigation to home page -->
    <servlet>
        <servlet-name>IndexServlet</servlet-name>
        <servlet-class>com.fakeurldetector.servlet.IndexServlet</servlet-class>
    </servlet>
    
    <!-- 
        ==========================================
        SERVLET MAPPING
        ==========================================
        
        <servlet-mapping> maps a URL pattern to a servlet:
        - When user visits /check, Tomcat calls CheckURLServlet
        - The servlet-name must match the name defined above
        
        URL Pattern rules:
        - /check        -> Exact match
        - /check/*      -> All URLs starting with /check/
        - *.do          -> All URLs ending with .do
        - /             -> Default servlet (catches everything else)
    -->
    <servlet-mapping>
        <servlet-name>CheckURLServlet</servlet-name>
        <url-pattern>/check</url-pattern>
    </servlet-mapping>
    
    <!-- Map /history URL to HistoryServlet -->
    <servlet-mapping>
        <servlet-name>HistoryServlet</servlet-name>
        <url-pattern>/history</url-pattern>
    </servlet-mapping>
    
    <!-- Map /index URL to IndexServlet -->
    <servlet-mapping>
        <servlet-name>IndexServlet</servlet-name>
        <url-pattern>/index</url-pattern>
    </servlet-mapping>
    
    <!-- 
        ==========================================
        WELCOME FILE LIST
        ==========================================
        
        Specifies which file to serve when user visits the app root
        without specifying a file name.
        
        Example: http://localhost:8080/FakeURLDetector/
        Tomcat will look for these files in order:
        1. index.jsp
        2. index.html
        
        First match wins.
    -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
    
</web-app>

